PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/wecom_crm
WECOM_TOKEN=your_wecom_token

# Google Gemini API key — required for PDF bill scanning
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
GEMINI_EMBED_MODEL=text-embedding-004

# Pinecone vector database — required for PDF semantic search
# Create an index with dimension 768 at https://app.pinecone.io
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=smartsense-catalogs
